ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Financial data is fetched using financialdatasets.ai
# Get your free API key at: https://financialdatasets.ai
FINANCIAL_DATASETS_API_KEY=your_financial_datasets_api_key_here

# Tavily API is used for web search to gather current market data
# Get your API key at: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Massive.com API is used for real-time market data (indices, sectors, VIX)
# Get your API key at: https://massive.com (formerly Polygon.io)
# Without this key, the Market Agent will use placeholder data
MASSIVE_API_KEY=your_massive_api_key_here
